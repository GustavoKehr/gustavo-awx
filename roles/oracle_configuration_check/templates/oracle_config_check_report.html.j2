<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Oracle Config Check — {{ oracle_sid }} — {{ ansible_date_time.date }}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
      background: #0f1117;
      color: #e2e8f0;
      min-height: 100vh;
      padding: 32px 24px;
    }

    /* ── Header ── */
    .header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 32px;
      padding-bottom: 24px;
      border-bottom: 1px solid #1e2433;
    }
    .header-left { flex: 1; }
    .header-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #1a1f2e;
      border: 1px solid #2d3748;
      border-radius: 8px;
      padding: 6px 14px;
      font-size: 12px;
      color: #94a3b8;
      margin-bottom: 14px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .header-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: #f59e0b; }
    h1 { font-size: 28px; font-weight: 700; color: #f1f5f9; letter-spacing: -0.5px; margin-bottom: 6px; }
    h1 span { color: #f59e0b; }
    .subtitle { font-size: 14px; color: #64748b; }
    .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; min-width: 240px; }
    .meta-item { background: #1a1f2e; border: 1px solid #1e2433; border-radius: 8px; padding: 12px 16px; }
    .meta-label { font-size: 10px; color: #64748b; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
    .meta-value { font-size: 14px; font-weight: 600; color: #e2e8f0; font-family: 'Courier New', monospace; }

    /* ── Summary cards ── */
    .summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
    .card {
      background: #1a1f2e;
      border: 1px solid #1e2433;
      border-radius: 12px;
      padding: 20px 24px;
      position: relative;
      overflow: hidden;
    }
    .card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
    .card-total::before { background: #475569; }
    .card-pass::before  { background: #10b981; }
    .card-fail::before  { background: #ef4444; }
    .card-fixed::before { background: #f59e0b; }
    .card-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: #64748b; margin-bottom: 10px; }
    .card-number { font-size: 40px; font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums; }
    .card-total  .card-number { color: #94a3b8; }
    .card-pass   .card-number { color: #10b981; }
    .card-fail   .card-number { color: #ef4444; }
    .card-fixed  .card-number { color: #f59e0b; }
    .card-sub { font-size: 12px; color: #475569; margin-top: 6px; }

    /* ── Progress bar ── */
    .progress-wrap { margin-bottom: 32px; }
    .progress-bar { height: 5px; background: #1e2433; border-radius: 3px; overflow: hidden; display: flex; }
    .progress-pass  { background: #10b981; }
    .progress-fixed { background: #f59e0b; }
    .progress-fail  { background: #ef4444; }
    .progress-labels { display: flex; justify-content: flex-end; gap: 20px; margin-top: 8px; font-size: 11px; color: #475569; }
    .progress-labels span { display: flex; align-items: center; gap: 5px; }
    .dot-pass  { width: 7px; height: 7px; border-radius: 50%; background: #10b981; }
    .dot-fixed { width: 7px; height: 7px; border-radius: 50%; background: #f59e0b; }
    .dot-fail  { width: 7px; height: 7px; border-radius: 50%; background: #ef4444; }

    /* ── Category section ── */
    .section { margin-bottom: 28px; }
    .section-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
    .section-title { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #94a3b8; }
    .section-line { flex: 1; height: 1px; background: #1e2433; }
    .section-count { font-size: 11px; color: #475569; background: #1a1f2e; border: 1px solid #1e2433; border-radius: 20px; padding: 2px 10px; }

    /* ── Table ── */
    .table-wrap { background: #13171f; border: 1px solid #1e2433; border-radius: 10px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead th {
      background: #0d111a;
      color: #475569;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
      padding: 10px 16px;
      text-align: left;
      border-bottom: 1px solid #1e2433;
    }
    tbody tr { border-bottom: 1px solid #0f1117; transition: background 0.12s; }
    tbody tr:hover { background: #141824; }
    tbody tr:last-child { border-bottom: none; }
    td { padding: 11px 16px; vertical-align: middle; }
    .id-cell { font-family: 'Courier New', monospace; font-size: 12px; color: #64748b; font-weight: 700; width: 55px; }
    .name-cell { color: #cbd5e1; }

    /* ── Badges ── */
    .badge {
      display: inline-flex; align-items: center; gap: 6px;
      border-radius: 6px; padding: 4px 10px;
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap;
    }
    .badge-pass  { background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.25); }
    .badge-fail  { background: rgba(239,68,68,0.12);  color: #ef4444; border: 1px solid rgba(239,68,68,0.25); }
    .badge-fixed { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.25); }

    .action-none  { color: #374151; font-size: 12px; }
    .action-fixed { color: #f59e0b; font-size: 12px; }
    .action-open  { color: #ef4444; font-size: 12px; }

    /* ── Footer ── */
    .footer {
      margin-top: 40px; padding-top: 20px;
      border-top: 1px solid #1e2433;
      display: flex; justify-content: space-between; align-items: center;
      font-size: 11px; color: #374151;
    }
    .footer strong { color: #475569; }
  </style>
</head>
<body>

{# ── Counters via namespace (Jinja2 2.10+, no list.append) ── #}
{% set ns = namespace(total=0, n_pass=0, n_fail=0, n_fixed=0) %}
{% for item in _sec_report | default([]) %}
  {% set ns.total = ns.total + 1 %}
  {% if item.status == 'PASS' %}
    {% set ns.n_pass = ns.n_pass + 1 %}
  {% elif item.fixed %}
    {% set ns.n_fixed = ns.n_fixed + 1 %}
  {% else %}
    {% set ns.n_fail = ns.n_fail + 1 %}
  {% endif %}
{% endfor %}

{% set pct_pass  = ((ns.n_pass  / ns.total * 100) | round(1)) if ns.total > 0 else 0 %}
{% set pct_fixed = ((ns.n_fixed / ns.total * 100) | round(1)) if ns.total > 0 else 0 %}
{% set pct_fail  = ((ns.n_fail  / ns.total * 100) | round(1)) if ns.total > 0 else 0 %}

{# ── Category definitions ── #}
{% set categories = [
  {'prefix': '1', 'label': 'Configuration',         'code': 'CONF'},
  {'prefix': '2', 'label': 'Error Prevention',       'code': 'ERR'},
  {'prefix': '3', 'label': 'Availability',           'code': 'AVAIL'},
  {'prefix': '4', 'label': 'Performance & Capacity', 'code': 'PERF'},
  {'prefix': '5', 'label': 'Operations',             'code': 'OP'},
] %}

<!-- ── Header ── -->
<div class="header">
  <div class="header-left">
    <div class="header-badge">
      <span class="dot"></span>
      Oracle 19c &nbsp;·&nbsp; Configuration Health Check
    </div>
    <h1>Database <span>{{ oracle_sid }}</span></h1>
    <p class="subtitle">{{ ansible_hostname }} &nbsp;·&nbsp; {{ oracle_home }} &nbsp;·&nbsp; {{ ansible_date_time.date }} {{ ansible_date_time.time }}</p>
  </div>
  <div class="meta-grid">
    <div class="meta-item">
      <div class="meta-label">Host</div>
      <div class="meta-value">{{ ansible_hostname }}</div>
    </div>
    <div class="meta-item">
      <div class="meta-label">SID</div>
      <div class="meta-value">{{ oracle_sid }}</div>
    </div>
    <div class="meta-item">
      <div class="meta-label">Version</div>
      <div class="meta-value">19c</div>
    </div>
    <div class="meta-item">
      <div class="meta-label">Remediation</div>
      <div class="meta-value">{{ 'ON' if oracle_configuration_check_remediate | default(true) | bool else 'OFF' }}</div>
    </div>
  </div>
</div>

<!-- ── Summary cards ── -->
<div class="summary">
  <div class="card card-total">
    <div class="card-label">Total Checks</div>
    <div class="card-number">{{ ns.total }}</div>
    <div class="card-sub">across 5 categories</div>
  </div>
  <div class="card card-pass">
    <div class="card-label">Pass</div>
    <div class="card-number">{{ ns.n_pass }}</div>
    <div class="card-sub">{{ pct_pass }}% compliant</div>
  </div>
  <div class="card card-fail">
    <div class="card-label">Fail · Open</div>
    <div class="card-number">{{ ns.n_fail }}</div>
    <div class="card-sub">manual action required</div>
  </div>
  <div class="card card-fixed">
    <div class="card-label">Fail → Fixed</div>
    <div class="card-number">{{ ns.n_fixed }}</div>
    <div class="card-sub">auto-remediated</div>
  </div>
</div>

<!-- ── Progress bar ── -->
<div class="progress-wrap">
  <div class="progress-bar">
    <div class="progress-pass"  style="width: {{ pct_pass  }}%"></div>
    <div class="progress-fixed" style="width: {{ pct_fixed }}%"></div>
    <div class="progress-fail"  style="width: {{ pct_fail  }}%"></div>
  </div>
  <div class="progress-labels">
    <span><span class="dot-pass"></span> Pass {{ pct_pass }}%</span>
    <span><span class="dot-fixed"></span> Fixed {{ pct_fixed }}%</span>
    <span><span class="dot-fail"></span> Fail {{ pct_fail }}%</span>
  </div>
</div>

<!-- ── Results by category ── -->
{% for cat in categories %}
  {# selectattr with 'match' anchors at start — safe in Ansible Jinja2 sandbox #}
  {% set cat_items = _sec_report | default([]) | selectattr('id', 'match', cat.prefix ~ '\\.') | list %}
  {% if cat_items | length > 0 %}

  <div class="section">
    <div class="section-header">
      <span class="section-title">{{ cat.code }} &nbsp;·&nbsp; {{ cat.label }}</span>
      <span class="section-line"></span>
      <span class="section-count">{{ cat_items | length }} checks</span>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Check</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          {% for item in cat_items %}
          <tr>
            <td class="id-cell">{{ item.id }}</td>
            <td class="name-cell">{{ item.name }}</td>
            <td>
              {% if item.status == 'PASS' %}
                <span class="badge badge-pass">&#10003; Pass</span>
              {% elif item.fixed %}
                <span class="badge badge-fixed">&#9874; Fixed</span>
              {% else %}
                <span class="badge badge-fail">&#10007; Fail</span>
              {% endif %}
            </td>
            <td>
              {% if item.status == 'PASS' %}
                <span class="action-none">—</span>
              {% elif item.fixed %}
                <span class="action-fixed">Auto-remediated</span>
              {% else %}
                <span class="action-open">Manual required</span>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  {% endif %}
{% endfor %}

<!-- ── Footer ── -->
<div class="footer">
  <span>Generated by <strong>oracle_configuration_check</strong> &nbsp;·&nbsp; Ansible Automation Platform</span>
  <span>{{ ansible_date_time.iso8601 }}</span>
</div>

</body>
</html>
