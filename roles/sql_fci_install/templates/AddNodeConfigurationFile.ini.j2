; SQL Server Failover Cluster Instance — Add Secondary Node
; Generated by Ansible — do not edit manually
[OPTIONS]
ACTION=AddNode
INSTANCENAME={{ fci_instance_name }}
FAILOVERCLUSTERNETWORKNAME="{{ fci_virtual_name }}"
FAILOVERCLUSTERIPADDRESSES="IPv4;{{ fci_virtual_ip }};{{ fci_cluster_network }};255.255.255.0"

; Service accounts must match primary node
SQLSVCACCOUNT="NT AUTHORITY\Network Service"
AGTSVCACCOUNT="NT AUTHORITY\Network Service"

; Silent install
QUIET=True
INDICATEPROGRESS=False
SQMREPORTING=0
ERRORREPORTING=0
IACCEPTSQLSERVERLICENSETERMS=True
