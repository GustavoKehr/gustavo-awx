; SQL Server Failover Cluster Instance — Primary Node Installation
; Generated by Ansible — do not edit manually
[OPTIONS]
ACTION=InstallFailoverCluster
FEATURES=SQLENGINE,CONN
INSTANCENAME={{ fci_instance_name }}
INSTANCEDIR="{{ fci_instance_dir }}"
INSTALLSHAREDDIR="C:\Program Files\Microsoft SQL Server"
INSTALLSHAREDWOWDIR="C:\Program Files (x86)\Microsoft SQL Server"

; Shared disk — cluster resource name must match exactly
FAILOVERCLUSTERDISKS="Cluster Disk 1"
FAILOVERCLUSTERNETWORKNAME="{{ fci_virtual_name }}"
FAILOVERCLUSTERIPADDRESSES="IPv4;{{ fci_virtual_ip }};{{ fci_cluster_network }};255.255.255.0"

; Data directories on shared disk
SQLUSERDBDIR="{{ fci_data_dir }}"
SQLUSERDBLOGDIR="{{ fci_log_dir }}"
SQLBACKUPDIR="{{ fci_backup_dir }}"
SQLTEMPDBDIR="{{ fci_data_dir }}"
SQLTEMPDBLOGDIR="{{ fci_log_dir }}"

; Authentication — SQL + Windows (mixed mode)
SECURITYMODE=SQL
SQLSYSADMINACCOUNTS="BUILTIN\Administrators"

; Service accounts — Network Service (language-independent SID S-1-5-20)
SQLSVCACCOUNT="NT AUTHORITY\Network Service"
AGTSVCACCOUNT="NT AUTHORITY\Network Service"

; Silent install
QUIET=True
INDICATEPROGRESS=False
SQMREPORTING=0
ERRORREPORTING=0
IACCEPTSQLSERVERLICENSETERMS=True
