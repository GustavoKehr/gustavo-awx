# chrony.conf — Ubuntu baseline
# Generated by Ansible (baseline_ubuntu role)

{% for server in chrony_ntp_servers %}
pool {{ server }} iburst
{% endfor %}

# Drift file
driftfile /var/lib/chrony/drift

# Allow makestep on large offset (first 3 clock updates)
makestep 1.0 3

# Enable kernel RTC sync
rtcsync

# Log directory
logdir /var/log/chrony

# Allow slewing only (no large step corrections after boot)
# makestep 0.1 -1
