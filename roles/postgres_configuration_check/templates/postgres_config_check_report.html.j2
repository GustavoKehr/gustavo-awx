<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>PostgreSQL Configuration Check — {{ inventory_hostname }}</title>
<style>
  body { font-family: Arial, sans-serif; margin: 30px; background: #f5f5f5; }
  h1 { color: #336699; }
  .meta { color: #666; margin-bottom: 20px; }
  table { border-collapse: collapse; width: 100%; background: #fff; }
  th { background: #336699; color: #fff; padding: 10px; text-align: left; }
  td { padding: 8px 10px; border-bottom: 1px solid #ddd; }
  tr:hover { background: #f0f4f8; }
  .pass { color: #2e7d32; font-weight: bold; }
  .fail { color: #c62828; font-weight: bold; }
  .summary { margin-top: 20px; padding: 10px; background: #fff; border-left: 4px solid #336699; }
</style>
</head>
<body>
<h1>PostgreSQL Configuration Check Report</h1>
<div class="meta">
  <strong>Host:</strong> {{ inventory_hostname }}<br>
  <strong>Date:</strong> {{ ansible_date_time.date }}<br>
  <strong>Remediation:</strong> {{ 'ON' if postgres_configuration_check_remediate else 'OFF' }}
</div>
<table>
  <tr>
    <th>#</th><th>Check</th><th>Status</th><th>Notes</th>
  </tr>
  {% for item in _pg_report %}
  <tr>
    <td>{{ item.id }}</td>
    <td>{{ item.name }}</td>
    <td class="{{ item.status | lower }}">{{ item.status }}</td>
    <td>{{ item.note | default('') }}</td>
  </tr>
  {% endfor %}
</table>
<div class="summary">
  <strong>PASS:</strong> {{ _pg_report | selectattr('status','equalto','PASS') | list | length }} |
  <strong>FAIL:</strong> {{ _pg_report | selectattr('status','equalto','FAIL') | list | length }} |
  <strong>Total:</strong> {{ _pg_report | length }}
</div>
</body>
</html>
