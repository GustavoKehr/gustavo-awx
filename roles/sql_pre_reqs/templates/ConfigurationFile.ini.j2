[OPTIONS]
; --- acao e licenca ---
ACTION="Install"
IACCEPTSQLSERVERLICENSETERMS="True"
QUIET="True"
QUIETSIMPLE="False"

; --- recursos e instancia ---
FEATURES=SQLENGINE,CONN
INSTANCEID="MSSQLSERVER"
INSTANCENAME="MSSQLSERVER"
UPDATEENABLED="False"

; --- diretorios ---
INSTANCEDIR="E:\SQLServer_Root"
SQLUSERDBDIR="E:\SQLServer_Root"
SQLUSERDBLOGDIR="E:\SQLServer_Root"
SQLTEMPDBDIR="E:\SQLServer_Root"
INSTALLSHAREDDIR="C:\Program Files\Microsoft SQL Server"
INSTALLSHAREDWOWDIR="C:\Program Files (x86)\Microsoft SQL Server"

; --- security e account ---
SECURITYMODE="SQL"
SQLSYSADMINACCOUNTS="{{ ansible_user }}"
; Adicionando a conta de serviço padrão (evita erros de permissão no E:)
SQLSVCACCOUNT="NT AUTHORITY\Network Service"
AGTSVCACCOUNT="NT AUTHORITY\Network Service"