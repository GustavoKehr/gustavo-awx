# Managed by Ansible — do not edit manually

[paths]
data  = {{ grafana_data_dir }}
logs  = {{ grafana_log_dir }}
plugins = {{ grafana_plugins_dir }}

[server]
http_addr = {{ grafana_http_addr | default('0.0.0.0') }}
http_port = {{ grafana_port }}
domain    = {{ grafana_domain if grafana_domain else ansible_default_ipv4.address }}
{% if grafana_root_url %}
root_url  = {{ grafana_root_url }}
{% else %}
root_url  = http://{{ grafana_domain if grafana_domain else ansible_default_ipv4.address }}:{{ grafana_port }}
{% endif %}

[security]
admin_user     = {{ grafana_admin_user }}
{% if grafana_admin_password is defined %}
admin_password = {{ grafana_admin_password }}
{% endif %}
disable_gravatar = true
cookie_secure    = false

[users]
allow_sign_up = false

[auth.anonymous]
enabled = false

{% if grafana_smtp_enabled | bool %}
[smtp]
enabled      = true
host         = {{ grafana_smtp_host }}
from_address = {{ grafana_smtp_from }}
from_name    = {{ grafana_smtp_from_name | default('Observabilidade') }}
{% endif %}

[unified_alerting]
enabled = true

[log]
mode  = console
level = warn
