{
  "name": "MYSQL | Manage Users v2",
  "description": "Individual survey questions for mysql_manage_users role.",
  "spec": [
    {
      "question_name": "MySQL username",
      "question_description": "MySQL account name to manage.",
      "required": true,
      "type": "text",
      "variable": "db_username",
      "min": 1,
      "max": 64,
      "default": ""
    },
    {
      "question_name": "MySQL user host",
      "question_description": "Use % for any host, or specific IP/CIDR (e.g. 10.10.10.5 or 10.10.10.0/24).",
      "required": true,
      "type": "text",
      "variable": "db_user_host",
      "min": 1,
      "max": 64,
      "default": "%"
    },
    {
      "question_name": "MySQL password",
      "question_description": "Required for create/update; leave blank for revoke/remove operations.",
      "required": false,
      "type": "password",
      "variable": "db_password",
      "default": ""
    },
    {
      "question_name": "User state",
      "question_description": "present = create/update/grant/revoke; absent = drop user account.",
      "required": true,
      "type": "multiplechoice",
      "variable": "db_user_state",
      "choices": "present\nabsent",
      "default": "present"
    },
    {
      "question_name": "Privileges",
      "question_description": "Comma-separated privileges (e.g. SELECT,INSERT,UPDATE). Use ALL for full access.",
      "required": true,
      "type": "text",
      "variable": "db_privileges",
      "min": 1,
      "max": 256,
      "default": "SELECT"
    },
    {
      "question_name": "Target databases",
      "question_description": "Comma-separated database names where privileges apply.",
      "required": true,
      "type": "textarea",
      "variable": "db_target_databases",
      "min": 1,
      "max": 1024,
      "default": "appdb"
    },
    {
      "question_name": "Revoke access",
      "question_description": "true = revoke the specified privileges instead of granting. User state must be present.",
      "required": true,
      "type": "multiplechoice",
      "variable": "db_revoke_access",
      "choices": "false\ntrue",
      "default": "false"
    },
    {
      "question_name": "Append privileges",
      "question_description": "true = add privileges without replacing existing grants. false = replace current grants.",
      "required": true,
      "type": "multiplechoice",
      "variable": "db_append_privileges",
      "choices": "true\nfalse",
      "default": "true"
    },
    {
      "question_name": "Create target databases",
      "question_description": "true = create target databases before performing grant operations.",
      "required": true,
      "type": "multiplechoice",
      "variable": "db_manage_databases",
      "choices": "false\ntrue",
      "default": "false"
    },
    {
      "question_name": "Allowed IPs (optional)",
      "question_description": "Comma-separated IPs or CIDRs to whitelist. Leave blank to skip IP restriction.",
      "required": false,
      "type": "textarea",
      "variable": "db_allowed_ips",
      "min": 0,
      "max": 2048,
      "default": ""
    }
  ]
}
